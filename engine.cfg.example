#==============================================================================
# ENGINE CONFIG
#==============================================================================
# hot-reload: press 'r' in the TUI to apply changes without restarting
# (except symbol, testnet, warmup_ticks — those need a restart)
#==============================================================================

# data source
symbol=btcusdt                  # binance trading pair
use_testnet=0                   # 1 = use binance testnet (fake data, safe for testing)
use_binance_us=0                # 1 = use binance US endpoint instead of global
poll_timeout_ms=100             # how long to wait for new data before running engine tick (ms)
reconnect_delay=5               # seconds to wait before reconnecting after disconnect
use_real_money=0                # 0 = paper trading (safe default)

# session lifecycle
wind_down_minutes=5             # minutes before 24h boundary to stop new buys and wind down

# warmup phase
warmup_ticks=100                # minimum raw ticks before trading
min_warmup_samples=128          # wait for short window to fill (128 x poll_interval ticks)

#==============================================================================
# REGRESSION GATE
#==============================================================================
# the engine uses P&L regression to shift the buy gate — if we're making money,
# buy more aggressively; if losing, tighten up. these control that feedback loop.

poll_interval=100               # ticks between slow-path runs (regression, adaptation, etc)
r2_threshold=0.30               # min R^2 to trust regression (0-1, higher = more conservative)
slope_scale_buy=0.50            # how much P&L slope shifts the buy price (higher = more reactive)
max_shift=0.001                 # max buy gate drift as fraction of price (0.001 = 0.1%)

#==============================================================================
# PAPER TRADING
#==============================================================================
starting_balance=10000.00       # initial paper trading balance ($)
fee_rate=0.10                   # trading fee per side (%, 0.10 = 0.1% per trade)
risk_pct=15.00                  # fraction of balance per position (%, 15 = $1500 at $10k balance)
slippage_pct=0.00               # simulated execution slippage (%, 0 = disabled, 0.05 = 0.05%)

#==============================================================================
# EXIT CONDITIONS
#==============================================================================
# TP and SL are computed from rolling volatility (stddev) at fill time.
# these percentages are multiplied by 100 to get the stddev multiplier:
# e.g. 6.00% -> 6.0x stddev. at stddev=$10, TP = entry + $60, SL = entry - $25.

take_profit_pct=3.00
stop_loss_pct=6.00

#==============================================================================
# ENTRY FILTERS
#==============================================================================
# these control WHEN the strategy buys. adapted by P&L regression at runtime.
# initial values set here, then the engine loosens/tightens based on performance.

volume_multiplier=1.00          # only buy when tick volume >= this * rolling avg
entry_offset_pct=0.200
spacing_multiplier=1.50         # min distance between entries = stddev * this

# how far the adaptive filters can drift from initial values
offset_min=0.03                 # most aggressive offset (%, smallest dip to buy)
offset_max=0.50                 # most defensive offset (%, largest dip required)
vol_mult_min=0.30               # most aggressive volume filter (lowest multiplier)
vol_mult_max=4.00               # most defensive volume filter (highest multiplier)
filter_scale=0.50               # how fast filters adapt (higher = faster response to P&L)

#==============================================================================
# RISK MANAGEMENT
#==============================================================================
max_drawdown_pct=10.00          # halt ALL buying if total P&L drops below this % of starting balance
max_exposure_pct=50.00          # max % of balance deployed in open positions
max_positions=6                 # max simultaneous open positions (1-16)

#==============================================================================
# ENHANCED BUY SIGNAL
#==============================================================================
# stddev-scaled offset: buy_price = avg - (stddev * mult)
# scales with volatility — wider dips required in volatile markets, tighter in calm ones

offset_stddev_mult=1.00         # stddev multiplier for buy offset (0 = use entry_offset_pct instead)
offset_stddev_min=0.20          # adaptation lower bound (most aggressive, 0.5 stddev dip)
offset_stddev_max=4.00          # adaptation upper bound (most defensive, 4.0 stddev dip)

# multi-timeframe gate: blocks buys when the 512-tick window shows a downtrend
min_long_slope=-0.0001          # block MR buys when 512-tick relative slope < this

#==============================================================================
# TRAILING TAKE-PROFIT
#==============================================================================
# when price runs past the original TP in a strong trend, the TP ratchets up
# to trail the price. captures extended runs instead of exiting at the first target.

tp_hold_score=0.10              # min score to hold past TP (0 = disabled, 0.1-0.3 typical)
tp_trail_mult=1.00              # trailing TP distance in stddevs below price
sl_trail_mult=2.00              # trailing SL distance in stddevs below price
fee_floor_mult=3.00             # TP floor = entry x fee_rate x this (3.0 = breakeven + margin)

#==============================================================================
# TIME-BASED EXIT
#==============================================================================
max_hold_ticks=75000            # close after this many ticks (~4-5 hours at 3 ticks/sec)
min_hold_gain_pct=0.10          # only time-exit if gain < this % (0.10 = 0.1%)

#==============================================================================
# REGIME DETECTION
#==============================================================================
# classifies market as RANGING (mean reversion), TRENDING (momentum), or VOLATILE (pause)

regime_slope_threshold=0.00002  # legacy (unused — crossover replaced slope-based detection)
regime_crossover_threshold=0.0005  # EMA/SMA spread for TRENDING
regime_r2_threshold=70.00       # min R^2 consistency for TRENDING (%, 70 = 0.70)
regime_volatile_stddev=0.0005   # stddev/price ratio for VOLATILE detection
regime_vol_spike_ratio=2.0      # variance spike: short/long variance > this = volatile
regime_hysteresis=5             # slow-path cycles before regime switch

#==============================================================================
# MOMENTUM STRATEGY
#==============================================================================
momentum_breakout_mult=1.50     # buy when price > avg + stddev * this
momentum_tp_mult=3.00           # TP distance in stddevs
momentum_sl_mult=1.50           # SL distance in stddevs
momentum_r2_min=0.40            # min R^2 to enter momentum
min_stddev_pct=0.00005          # skip fills when stddev/price < this
min_buy_delta=-0.30             # min volume delta for MR buys
vwap_offset=0.00                # buy below VWAP by this fraction (0 = disabled)

#==============================================================================
# GATE RECOVERY
#==============================================================================
idle_reset_cycles=30            # cycles before gate decay (0 = disabled)

#==============================================================================
# PARTIAL EXITS (SCALING OUT)
#==============================================================================
partial_exit_enabled=1          # 0 = full exits only, 1 = split into two legs
partial_exit_pct=0.50           # fraction of qty for TP1 leg (0.5 = 50/50 split)
tp2_mult=2.00                   # TP2 distance = TP1 distance * this
breakeven_on_partial=1          # move remaining SL to entry price after TP1 hit

#==============================================================================
# ORDER BOOK (L2 DEPTH)
#==============================================================================
depth_enabled=0                 # 0 = trade stream only, 1 = also subscribe to depth
min_book_imbalance=0.00         # require bid excess to buy (0 = disabled)

#==============================================================================
# SESSION AWARENESS
#==============================================================================
session_filter_enabled=1        # 0 = disabled (treat all hours the same)
session_asian_mult=1.50         # wider gates during low-vol Asian session
session_european_mult=1.00      # normal during European session
session_us_mult=0.80            # tighter gates during US session (best liquidity)
session_overnight_mult=1.30     # wider gates overnight

#==============================================================================
# STRATEGY SELECTION
#==============================================================================
# -1 = regime auto (MR in ranging, Momentum in trending)
#  0 = Mean Reversion only        1 = Momentum only
#  2 = Simple Dip                 3 = ML (model-driven)

default_strategy=2

#==============================================================================
# EMA GATE (PROACTIVE ENTRY)
#==============================================================================
gate_ema_enabled=1              # 0 = use rolling avg (legacy), 1 = use EMA for gate
gate_ema_alpha=0.9900

#==============================================================================
# RISK INFRASTRUCTURE
#==============================================================================
# kill switch: sticky trading halt on daily loss or drawdown breach
kill_switch_enabled=1           # 0 = disabled, 1 = enabled
kill_switch_daily_loss_pct=3.00 # max daily loss before kill (%)
kill_switch_drawdown_pct=5.00   # max drawdown from session peak (%)
kill_recovery_warmup=50         # slow-path cycles to observe after kill reset

# vol-scaled sizing: scale position qty inversely with volatility
vol_sizing_enabled=1            # 0 = fixed risk_pct sizing, 1 = vol-scaled
vol_scale_min=0.25              # minimum scale factor (25% of base qty)
vol_scale_max=2.00              # maximum scale factor (200% of base qty)

# no-trade band: suppress entries when signal strength < fee breakeven
no_trade_band_enabled=1         # 0 = disabled, 1 = cost-aware signal gate
no_trade_band_mult=3.00         # signal must exceed fee_rate * this to trade

#==============================================================================
# ML INFERENCE (experimental — requires -DUSE_XGBOOST=ON or -DUSE_LIGHTGBM=ON)
#==============================================================================
# 0=disabled (default, zero overhead), 1=xgboost, 2=lightgbm
ml_backend=0
ml_model_path=
ml_buy_threshold=0.60           # prediction > this = buy signal
ml_tp_pct=1.50                  # take profit % for ML positions
ml_sl_pct=0.80                  # stop loss % for ML positions

# regime enrichment model (Mode A — improves classification for all strategies)
regime_model_backend=0
regime_model_path=
regime_model_weight=2           # score weight added to trending_score

#==============================================================================
# TUI
#==============================================================================
tui_enabled=1                   # 0 = headless mode (for VPS/tmux), 1 = terminal dashboard
tui_render_interval=10          # render every N ticks (higher = less terminal thrash)
